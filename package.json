  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/*/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@soenglish/web",
    "dev:api": "turbo run dev --filter=@soenglish/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@soenglish/web",
    "build:api": "turbo run build --filter=@soenglish/api",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "prisma:generate": "prisma generate --schema packages/backend/data-access/data-access-prisma/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema packages/backend/data-access/data-access-prisma/prisma/schema.prisma"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.8.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "prettier": "~3.6.2",
    "prisma": "^7.7.0",
    "sass": "1.62.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.3.0",
    "tsx": "^4.20.6",
    "turbo": "^2.5.5",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0"
  },
