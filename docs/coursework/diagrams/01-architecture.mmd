%% Рис. 1 — Загальна архітектура SoEnglish
flowchart TB
  subgraph Client["Клієнт"]
    Browser["Браузер"]
  end

  subgraph Web["apps/web — Next.js :4200"]
    Pages["App Router / UI"]
    Stores["Zustand stores"]
    GQLClient["GraphQL + REST client"]
    WS["Socket.IO client"]
  end

  subgraph Proxy["Next.js rewrite"]
    ApiProxy["/api/* → Nest"]
  end

  subgraph API["apps/api — NestJS :3000"]
    GQL["GraphQL /api/graphql"]
    REST["REST /api/auth, /api/lessons, …"]
    ChatGW["WebSocket chat"]
    Modules["packages/backend/modules"]
  end

  subgraph Data["Дані та інтеграції"]
    Prisma["Prisma Client"]
    PG[("PostgreSQL")]
    Google["Google OAuth / Calendar / Meet"]
  end

  Browser --> Pages
  Pages --> Stores
  Pages --> GQLClient
  Pages --> WS
  GQLClient --> ApiProxy
  WS --> API
  ApiProxy --> GQL
  ApiProxy --> REST
  GQL --> Modules
  REST --> Modules
  ChatGW --> Modules
  Modules --> Prisma
  Prisma --> PG
  Modules --> Google
