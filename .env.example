# =============================================================================
# Arvilio — SINGLE env file for the whole monorepo (repo root only).
# Copy: cp .env.example .env
#
# Used by: apps/api (load-env.ts), apps/campus + apps/platform + apps/hub + apps/cms (next.config →
# scripts/load-root-env.mjs), Docker Compose, Prisma. Do NOT create apps/*/.env.
# =============================================================================

DATABASE_URL=postgresql://soenglish:soenglish@localhost:5432/soenglish?schema=public

# --- Payload CMS (@app/cms, port 4410) ---
PAYLOAD_SECRET=change-me-in-production-min-32-chars!!
# Optional override; defaults to DATABASE_URL. Campus uses schema `payload`; company CMS uses `payload_www`.
# PAYLOAD_DATABASE_URL=
# PAYLOAD_WWW_SCHEMA=payload_www
# CMS_ADMIN_EMAIL=cms@arvilio.local
# CMS_ADMIN_PASSWORD=change-me-www-cms-admin
CMS_URL=http://127.0.0.1:4410
CMS_ORIGIN=http://localhost:4410
# NEXT_PUBLIC_CMS_URL=http://localhost:4410

# --- Origins ---
# Browser uses same-origin /api (Next.js rewrite) so auth cookies persist.
API_URL=http://localhost:3000/api
API_PROXY_TARGET=http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000
WEB_ORIGIN=http://localhost:4200
# Marketing hub (apps/hub) — product CTAs
NEXT_PUBLIC_CAMPUS_URL=http://localhost:4200
# NEXT_PUBLIC_CONNECT_URL=http://localhost:4500
HUB_ORIGIN=http://localhost:4400
# WWW_ORIGIN=http://localhost:4400 # deprecated alias; use HUB_ORIGIN
CHAT_UPLOAD_DIR=./data/chat-uploads
# DEBUG_PROXY_TIMING=1
# WEB_SESSION_CACHE_TTL_MS=8000

# --- Authentication ---
JWT_SECRET=replace-me-with-long-random-string
SUPER_ADMIN_CLI_SECRET=

# --- Secrets encryption (System → Email / Connections / translation / platform billing rails) ---
PLATFORM_SECRETS_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# --- Platform subscription billing (Layer B / ADR-010; Control Plane Settings can override) ---
# STRIPE_PLATFORM_SECRET_KEY=
# STRIPE_PLATFORM_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_PRO=

# --- Dictionary lookup (active provider: System → Word dictionary) ---
DICTIONARY_API_URL=https://api.dictionaryapi.dev/api/v2/entries/en/
WIKTIONARY_API_URL=https://en.wiktionary.org/api/rest_v1/page/definition/
WIKTIONARY_USER_AGENT=Arvilio/1.0 (vocabulary)

# --- Translation providers (active provider: System → Word dictionary) ---
TRANSLATION_API_URL=https://api.mymemory.translated.net/get
REVERSO_API_URL=https://api.reverso.net/translate/v1/translation
DEEPL_API_URL=https://api-free.deepl.com
GOOGLE_TRANSLATE_API_URL=https://translation.googleapis.com
AZURE_TRANSLATOR_URL=https://api.cognitive.microsofttranslator.com
# TRANSLATION_API_EMAIL=
# DEEPL_AUTH_KEY=
# GOOGLE_TRANSLATE_API_KEY=
# AZURE_TRANSLATOR_KEY=
# AZURE_TRANSLATOR_REGION=eastus
# LIBRETRANSLATE_URL=http://127.0.0.1:5001
# LIBRETRANSLATE_API_KEY=
# REVERSO_CONTEXT_TARGET_LANG=uk

# --- SMTP (Platform Settings / System → Email; or bootstrap here) ---
# Any SMTP provider works (Resend, Brevo, SES, Mailtrap, …).
# MAIL_FROM=noreply@your-domain.com
#
# Resend example:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_xxxx
#
# Brevo example:
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
#
# Mailtrap sandbox (dev capture only):
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=
# SMTP_PASS=

# --- OAuth & integrations (configure in System UI; optional env fallbacks) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# TELEGRAM_BOT_TOKEN=

# --- Zoom (video meetings — configure in System → Connections) ---
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_CALLBACK_URL=http://localhost:3000/api/auth/zoom/callback
# ZOOM_WEBHOOK_SECRET_TOKEN=
# ZOOM_ACCOUNT_ID=

# --- LiveKit (built-in video — self-hosted via infra/docker/docker-compose.yml) ---
# Must match keys in infra/docker/livekit.yaml (secret ≥ 32 chars).
# LIVEKIT_URL is the standard var name (LIVEKIT_WS_URL is a legacy alias).
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=arvilio-local-livekit-dev-secret-do-not-use-in-prod
# Production example:
# LIVEKIT_URL=wss://livekit.your-domain.com
# LIVEKIT_API_KEY=your-key
# LIVEKIT_API_SECRET=your-secret-at-least-32-chars

# --- Materials library ---
# MATERIAL_UPLOAD_DIR=data/material-uploads
# MATERIAL_ATTACHMENT_MAX_BYTES=104857600
# NEXT_PUBLIC_MATERIAL_ATTACHMENT_MAX_BYTES=104857600
# MATERIAL_COMPRESS_ENABLED=true
# MATERIAL_COMPRESS_IMAGES=true
# MATERIAL_COMPRESS_AUDIO=true
# MATERIAL_COMPRESS_VIDEO=true
# MATERIAL_COMPRESS_PDF=true
# MATERIAL_DEFER_PDF_COMPRESS=true
# MATERIAL_IMAGE_WEBP_QUALITY=82
# MATERIAL_IMAGE_JPEG_QUALITY=85
# MATERIAL_AUDIO_BITRATE=128k
# MATERIAL_VIDEO_CRF=28
# MATERIAL_FFMPEG_BIN=ffmpeg
# MATERIAL_GHOSTSCRIPT_BIN=gs
# MATERIAL_PDF_IMAGE_DPI=150
# MATERIAL_PDF_SETTINGS=/ebook
# MATERIAL_COMPRESS_TIMEOUT_MS=300000

# --- Whisper (auto-captions after audio/video upload) ---
# MATERIAL_WHISPER_BIN=whisper-cli
# MATERIAL_WHISPER_MODEL=/Users/you/ggml-base.bin
# MATERIAL_WHISPER_TIMEOUT_MS=600000
# OPENAI_WHISPER_API_KEY=sk-...
# MATERIAL_CAPTIONS_ENABLED=true
