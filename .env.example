DATABASE_URL=postgresql://soenglish:soenglish@localhost:5432/soenglish?schema=public

# --- Payload CMS ---
PAYLOAD_SECRET=change-me-in-production-min-32-chars!!

# --- Origins ---
# Browser uses same-origin /api (Next.js rewrite) so auth cookies persist.
API_URL=http://localhost:3000/api
API_PROXY_TARGET=http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000
WEB_ORIGIN=http://localhost:4200
CHAT_UPLOAD_DIR=./data/chat-uploads
# DEBUG_PROXY_TIMING=1
# WEB_SESSION_CACHE_TTL_MS=8000

# --- Authentication ---
JWT_SECRET=replace-me-with-long-random-string
SUPER_ADMIN_CLI_SECRET=

# --- Secrets encryption (System → Email / Connections / translation) ---
PLATFORM_SECRETS_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# --- Dictionary lookup (active provider: System → Word dictionary) ---
DICTIONARY_API_URL=https://api.dictionaryapi.dev/api/v2/entries/en/
WIKTIONARY_API_URL=https://en.wiktionary.org/api/rest_v1/page/definition/
WIKTIONARY_USER_AGENT=SoEnglish/1.0 (vocabulary)

# --- Translation providers (active provider: System → Word dictionary) ---
TRANSLATION_API_URL=https://api.mymemory.translated.net/get
REVERSO_API_URL=https://api.reverso.net/translate/v1/translation
DEEPL_API_URL=https://api-free.deepl.com
GOOGLE_TRANSLATE_API_URL=https://translation.googleapis.com
AZURE_TRANSLATOR_URL=https://api.cognitive.microsofttranslator.com
# TRANSLATION_API_EMAIL=
# DEEPL_AUTH_KEY=
# GOOGLE_TRANSLATE_API_KEY=
# AZURE_TRANSLATOR_KEY=
# AZURE_TRANSLATOR_REGION=eastus
# LIBRETRANSLATE_URL=http://127.0.0.1:5001
# LIBRETRANSLATE_API_KEY=
# REVERSO_CONTEXT_TARGET_LANG=uk

# --- SMTP (configure in System → Email; or bootstrap here) ---
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=
# SMTP_PASS=

# --- OAuth & integrations (configure in System UI; optional env fallbacks) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# TELEGRAM_BOT_TOKEN=

# --- Zoom (video meetings — configure in System → Connections) ---
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_CALLBACK_URL=http://localhost:3000/api/auth/zoom/callback
# ZOOM_WEBHOOK_SECRET_TOKEN=
# ZOOM_ACCOUNT_ID=

# --- LiveKit (built-in video — self-hosted via infra/docker/docker-compose.yml) ---
# Dev defaults are built into the code (ws://localhost:7880 / devkey / devsecret).
# Override in production — LIVEKIT_URL is the standard var name:
# LIVEKIT_URL=wss://livekit.your-domain.com
# LIVEKIT_API_KEY=your-key
# LIVEKIT_API_SECRET=your-secret

