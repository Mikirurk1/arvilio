DATABASE_URL=postgresql://soenglish:soenglish@localhost:5432/soenglish?schema=public

# API / web origins
# Browser uses same-origin /api (Next.js rewrite) so auth cookies persist.
API_URL=http://localhost:3000/api
API_PROXY_TARGET=http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=/api
# Socket.IO chat (direct to API — WebSocket is not proxied through Next)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000
# Chat file uploads (deleted after 24h)
CHAT_UPLOAD_DIR=./data/chat-uploads
WEB_ORIGIN=http://localhost:4200
# Set to 1 to log proxy web-session duration (ms) and emit x-soenglish-proxy-ms response header
# DEBUG_PROXY_TIMING=1
# Short-lived in-process cache for proxy web-session (ms). Speeds up back-to-back navigations.
# WEB_SESSION_CACHE_TTL_MS=8000

# Authentication
JWT_SECRET=replace-me-with-long-random-string
# Secret used to sign short-lived JWTs for the `super-admin` CLI. Required to
# create or remove SUPER_ADMIN accounts. Set to a long random string.
SUPER_ADMIN_CLI_SECRET=

# Google OAuth (Sign-in + Calendar/Meet for teachers)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
GOOGLE_SUCCESS_REDIRECT=http://localhost:4200/dashboard
# After linking Google from Profile → Connections (optional; defaults to WEB_ORIGIN/profile?tab=connections)
# GOOGLE_LINK_SUCCESS_REDIRECT=http://localhost:4200/profile
# Optional; defaults to WEB_ORIGIN/login?error=no_account when Google sign-in has no provisioned user
# GOOGLE_FAILURE_REDIRECT=http://localhost:4200/login?error=no_account

# Facebook OAuth (Profile → Connections)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# Telegram (Profile → Connections) — create via @BotFather /newbot
TELEGRAM_BOT_TOKEN=
# Optional; API can resolve username via getMe
TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
TELEGRAM_DEV_POLLING=true
# Localhost bot /start linking needs long polling (Login Widget does not work on localhost).
# Opt-in only — set true while testing Profile → Connect via Telegram; leave unset otherwise.
# TELEGRAM_DEV_POLLING=true

# Dictionary enrichment (super-admin can switch provider in System → Word dictionary)
DICTIONARY_API_URL=https://api.dictionaryapi.dev/api/v2/entries/en/
WIKTIONARY_API_URL=https://en.wiktionary.org/api/rest_v1/page/definition/
WIKTIONARY_USER_AGENT=SoEnglish/1.0 (vocabulary)
# Translations (MyMemory free tier is ~5k chars/day/IP; add email for ~50k — no signup)
TRANSLATION_API_URL=https://api.mymemory.translated.net/get
TRANSLATION_API_EMAIL=
# Fallback when MyMemory quota is hit (default: enabled). Set to "false" to disable.
# TRANSLATION_GTX_FALLBACK=false
# Optional LibreTranslate instance:
# LIBRETRANSLATE_URL=https://libretranslate.example.com
# LIBRETRANSLATE_API_KEY=

# Transactional email (Mailtrap for development)
# https://mailtrap.io/ → Email Testing → SMTP credentials
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
MAIL_FROM=SoEnglish <noreply@soenglish.local>

# Lesson billing
# Platform-wide infra:
# WEB_APP_URL=http://localhost:4200
# API_PUBLIC_URL=http://localhost:3000/api
# PAYMENT_SECRETS_ENCRYPTION_KEY=change-me-to-a-long-random-secret

