{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@tests/integration/*": ["tests/integration/*"],
      "@fe/ui": ["packages/frontend/shared-ui/src/index.ts"],
      "@fe/utils": ["packages/frontend/shared-utils/src/index.ts"],
      "@fe/vocabulary": ["packages/frontend/feature-vocabulary/src/index.ts"],
      "@fe/flashcards": ["packages/frontend/feature-flashcards/src/index.ts"],
      "@fe/lessons": ["packages/frontend/feature-lessons/src/index.ts"],
      "@fe/progress": ["packages/frontend/feature-progress/src/index.ts"],
      "@be/graphql": ["packages/backend/shared/graphql/src/index.ts"],
      "@be/storage": ["packages/backend/shared/storage/src/index.ts"],
      "@be/auth": ["packages/backend/modules/module-auth/src/index.ts"],
      "@be/vocabulary": ["packages/backend/modules/module-vocabulary/src/index.ts"],
      "@be/platform-integration": [
        "packages/backend/modules/module-vocabulary/src/application/platform-integration/index.ts"
      ],
      "@be/flashcards": ["packages/backend/modules/module-flashcards/src/index.ts"],
      "@be/speaking": ["packages/backend/modules/module-speaking/src/index.ts"],
      "@be/materials": ["packages/backend/modules/module-materials/src/index.ts"],
      "@be/lessons": ["packages/backend/modules/module-lessons/src/index.ts"],
      "@be/progress": ["packages/backend/modules/module-progress/src/index.ts"],
      "@be/platform-admin": ["packages/backend/modules/module-platform-admin/src/index.ts"],
      "@be/email-templates": ["packages/backend/email-templates/dist/index.d.ts"],
      "@be/mail": ["packages/backend/modules/module-mail/src/index.ts"],
      "@be/notifications": ["packages/backend/modules/module-notifications/src/index.ts"],
      "@be/notifications/telegram": [
        "packages/backend/modules/module-notifications/src/infrastructure/telegram-bot.client.ts"
      ],
      "@be/chat": ["packages/backend/modules/module-chat/src/index.ts"],
      "@be/billing": ["packages/backend/modules/module-billing/src/index.ts"],
      "@be/billing/entitlements": ["packages/backend/modules/module-billing/src/entitlements.ts"],
      "@be/prisma": ["packages/backend/data-access/data-access-prisma/src/index.ts"],
      "@be/tenant": ["packages/backend/shared/tenant/src/index.ts"],
      "@pkg/types": ["packages/shared/types/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
