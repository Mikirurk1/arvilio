{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",

    "strict": true,
    "noEmit": true,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@soenglish/shared-ui": ["../../packages/frontend/shared-ui/src/index.ts"],
      "@soenglish/shared-utils": ["../../packages/frontend/shared-utils/src/index.ts"],
      "@soenglish/feature-vocabulary": ["../../packages/frontend/feature-vocabulary/src/index.ts"],
      "@soenglish/feature-flashcards": ["../../packages/frontend/feature-flashcards/src/index.ts"],
      "@soenglish/feature-lessons": ["../../packages/frontend/feature-lessons/src/index.ts"],
      "@soenglish/feature-progress": ["../../packages/frontend/feature-progress/src/index.ts"],
      "@soenglish/backend-core": ["../../packages/backend/core/src/index.ts"],
      "@soenglish/module-auth": ["../../packages/backend/modules/module-auth/src/index.ts"],
      "@soenglish/module-vocabulary": ["../../packages/backend/modules/module-vocabulary/src/index.ts"],
      "@soenglish/module-flashcards": ["../../packages/backend/modules/module-flashcards/src/index.ts"],
      "@soenglish/module-lessons": ["../../packages/backend/modules/module-lessons/src/index.ts"],
      "@soenglish/module-progress": ["../../packages/backend/modules/module-progress/src/index.ts"],
      "@soenglish/data-access-prisma": ["../../packages/backend/data-access/data-access-prisma/src/index.ts"],
      "@soenglish/shared-types": ["../../packages/shared/types/src/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",

    "../../apps/web/.next/types/**/*.ts",
    "../../dist/apps/web/.next/types/**/*.ts",

    "next-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "jest.config.ts",
    "jest.config.cts",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
