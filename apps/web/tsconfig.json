{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",

    "strict": true,
    "noEmit": true,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@fe/ui": ["../../packages/frontend/shared-ui/src/index.ts"],
      "@fe/utils": ["../../packages/frontend/shared-utils/src/index.ts"],
      "@fe/vocabulary": ["../../packages/frontend/feature-vocabulary/src/index.ts"],
      "@fe/flashcards": ["../../packages/frontend/feature-flashcards/src/index.ts"],
      "@fe/lessons": ["../../packages/frontend/feature-lessons/src/index.ts"],
      "@fe/progress": ["../../packages/frontend/feature-progress/src/index.ts"],
      "@be/graphql": ["../../packages/backend/shared/graphql/src/index.ts"],
      "@be/auth": ["../../packages/backend/modules/module-auth/src/index.ts"],
      "@be/vocabulary": ["../../packages/backend/modules/module-vocabulary/src/index.ts"],
      "@be/flashcards": ["../../packages/backend/modules/module-flashcards/src/index.ts"],
      "@be/lessons": ["../../packages/backend/modules/module-lessons/src/index.ts"],
      "@be/progress": ["../../packages/backend/modules/module-progress/src/index.ts"],
      "@be/prisma": ["../../packages/backend/data-access/data-access-prisma/src/index.ts"],
      "@pkg/types": ["../../packages/shared/types/src/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",

    "../../apps/web/.next/types/**/*.ts",
    "../../dist/apps/web/.next/types/**/*.ts",

    "next-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts"
  ]
}
