generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================
// Auth and user model
// =====================

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
  SUPER_ADMIN
}

enum UserAccountStatus {
  ACTIVE
  PAUSED
  LEAVED
  BLOCKED
}

enum ProficiencyLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

/// Catalog of supported languages (ISO 639-1 code).
model Language {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  isActive Boolean @default(true)

  nativeUsers     User[]                    @relation("UserNativeLanguage")
  learningLinks   StudentLearningLanguage[]
  wordDefinitions WordDefinition[]
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  /// Optional for users registered via Google only.
  passwordHash     String?
  displayName      String
  avatarUrl        String?
  role             UserRole          @default(STUDENT)
  status           UserAccountStatus @default(ACTIVE)
  proficiencyLevel ProficiencyLevel?
  /// IANA timezone identifier, e.g. "Europe/Kyiv".
  timezone         String            @default("Europe/Kyiv")
  /// E.164-style phone, e.g. "+380671234567".
  phone            String?
  /// Telegram handle, e.g. "@username".
  telegram         String?
  bio              String?
  /// Native language for UI translations.
  nativeLanguageId String?
  nativeLanguage   Language? @relation("UserNativeLanguage", fields: [nativeLanguageId], references: [id], onDelete: SetNull)
  /// Teacher assigned to a student. Null for non-student roles.
  teacherId        String?
  teacher          User?             @relation("StudentTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  /// Students only: `true` = fixed schedule (recurrence allowed), `false` = flexible.
  scheduleType     Boolean           @default(true)
  /// Students only: which lesson formats the student may attend.
  lessonFormat     StudentLessonFormat @default(MIXED)
  /// Calendar / roster accent color (#RRGGBB). Assigned on create; staff may edit.
  displayColor     String?
  students         User[]            @relation("StudentTeacher")
  learningLanguages StudentLearningLanguage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  oauthAccounts OAuthAccount[]
  refreshTokens AuthRefreshToken[]
  passwordResetTokens PasswordResetToken[]

  vocabularyCards StudentWordCard[]
  progress        Progress[]
  reviewQueue     ReviewQueue[]

  lessonsAsTeacher ScheduledLesson[] @relation("LessonTeacher")
  lessonsAsStudent ScheduledLesson[] @relation("LessonStudent")
  scheduledLessonParticipations ScheduledLessonParticipant[]
  groupLessonsAsPayer         ScheduledLesson[]            @relation("GroupLessonPayer")
  studentGroupMemberships     StudentGroupMember[]
  studentGroupsLed            StudentGroup[]               @relation("StudentGroupTeacher")
  studentGroupsPaying         StudentGroup[]               @relation("StudentGroupPayer")

  ownedQuizzes        Quiz[]           @relation("QuizOwner")
  assignedQuizzes     QuizAssignment[] @relation("AssignmentStudent")
  authoredAssignments QuizAssignment[] @relation("AssignmentAssignedBy")
  quizAttempts        QuizAttempt[]

  ownedSpeakingTopics         SpeakingTopic[]           @relation("SpeakingTopicOwner")
  speakingAssignments         SpeakingTopicAssignment[] @relation("SpeakingAssignmentStudent")
  authoredSpeakingAssignments SpeakingTopicAssignment[] @relation("SpeakingAssignmentAssignedBy")
  speakingSubmissions         SpeakingSubmission[]      @relation("SpeakingSubmissionStudent")
  reviewedSpeakingSubmissions SpeakingSubmission[]      @relation("SpeakingSubmissionReviewer")

  calendarConnection GoogleCalendarConnection?
  zoomConnection     ZoomConnection?

  notifyLessonReminder   Boolean @default(true)
  notifyStreakAlert      Boolean @default(true)
  notifyWeeklyReport     Boolean @default(true)
  notifyNewVocab         Boolean @default(false)
  notifyTeacherMessages  Boolean @default(true)

  telegramLinkTokens     TelegramLinkToken[]
  notificationDeliveries NotificationDelivery[]
  messagesSent           TeacherMessage[]       @relation("MessageTeacher")
  messagesReceived       TeacherMessage[]       @relation("MessageStudent")
  practiceSessions       PracticeSession[]
  dailyGoalCompletions   DailyGoalCompletion[]
  chatConversationsCreated ChatConversation[]   @relation("ChatCreatedBy")
  chatParticipants         ChatParticipant[]
  chatMessagesSent           ChatMessage[]

  lessonBalance           StudentLessonBalance?
  lessonBalanceLedger     LessonBalanceLedger[] @relation("LessonBalanceLedgerUser")
  lessonBalanceAdjustments LessonBalanceLedger[] @relation("LessonBalanceLedgerCreatedBy")
  payments                Payment[]

  libraryMaterialsCreated LibraryMaterial[] @relation("LibraryMaterialCreator")
  libraryFileAnnotations  LibraryFileUserAnnotation[]

  staffCompensationProfile StaffCompensationProfile?
  staffPayoutsReceived     StaffPayout[]             @relation("StaffPayoutPayee")
  staffPayoutsCreated      StaffPayout[]             @relation("StaffPayoutCreator")

  @@index([teacherId])
  @@index([nativeLanguageId])
}

enum PracticeSessionKind {
  VOCABULARY
  QUIZ
  SPEAKING
  GAMES
  CHALLENGES
  LESSON
}

enum PracticeSessionSource {
  PRACTICE
  LESSON
  MANUAL
}

model PracticeSession {
  id          String                @id @default(cuid())
  userId      String
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        PracticeSessionKind
  source      PracticeSessionSource @default(PRACTICE)
  startedAt   DateTime
  endedAt     DateTime
  durationSec Int

  createdAt DateTime @default(now())

  @@index([userId, startedAt])
}

/// Student daily goal completion (UTC date key, one row per difficulty tier per day).
model DailyGoalCompletion {
  id          String   @id @default(cuid())
  userId      String
  dateKey     String
  templateId  String
  difficulty  Int
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey, difficulty])
  @@index([userId, dateKey])
}

enum NotificationKind {
  LESSON_REMINDER
  STREAK_ALERT
  WEEKLY_REPORT
  NEW_VOCAB
  TEACHER_MESSAGE
}

model NotificationDelivery {
  id        String           @id @default(cuid())
  userId    String
  kind      NotificationKind
  dedupeKey String
  channel   String           @default("email")
  sentAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, dedupeKey, channel])
  @@index([userId, kind])
}

model TeacherMessage {
  id        String   @id @default(cuid())
  teacherId String
  studentId String
  body      String
  createdAt DateTime @default(now())

  teacher User @relation("MessageTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("MessageStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@index([teacherId, createdAt])
}

/// Languages a student is learning (admin-managed only).
model StudentLearningLanguage {
  userId     String
  languageId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@id([userId, languageId])
  @@index([languageId])
}

enum OAuthProvider {
  GOOGLE
  FACEBOOK
  TELEGRAM
}

/// Short-lived token for linking Telegram via bot /start (works on localhost; no Login Widget domain).
model TelegramLinkToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("telegram_link_tokens")
}

model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String
  provider          OAuthProvider
  providerAccountId String
  /// Email or handle returned by the provider.
  providerEmail     String?
  /// Encrypted at the application layer when storing refresh tokens.
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  scopes            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuthRefreshToken {
  id        String    @id @default(cuid())
  userId    String
  /// SHA-256 hash of the refresh token. The raw token is never stored.
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id                   String   @id @default(cuid())
  userId               String
  tokenHash            String   @unique
  expiresAt            DateTime
  usedAt               DateTime?
  requestedByIp        String?
  requestedByUserAgent String?
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Google Calendar connection used to create Meet links for scheduled lessons.
model GoogleCalendarConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  /// Calendar id used when creating events. Defaults to "primary".
  calendarId   String    @default("primary")
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  scopes       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Zoom OAuth connection used to create Zoom meetings for scheduled lessons.
model ZoomConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  zoomUserId   String?
  accountId    String?
  email        String?
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  scopes       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// =====================
// Vocabulary
// =====================

model Word {
  id             String   @id @default(cuid())
  /// Original word text as provided.
  text           String
  /// Lowercased text used for unique lookups.
  normalizedText String   @unique
  definition     String
  example        String?
  phonetic       String?
  partOfSpeech   String?
  category       String?
  audioUrl       String?
  /// Etymology / origin line from dictionary providers.
  origin         String?
  synonyms       String[]
  antonyms       String[]
  /// Source provider, e.g. "dictionaryapi.dev" or "manual".
  source         String?
  /// Raw provider payload kept for re-enrichment / audit.
  sourcePayload  Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cards         StudentWordCard[]
  reviewQueue   ReviewQueue[]
  quizQuestions QuizQuestion[]
  definitions   WordDefinition[]

  @@index([category])
}

/// Localized definition text for a word.
model WordDefinition {
  id         String   @id @default(cuid())
  wordId     String
  languageId String
  /// Translated definition / meaning in this language.
  text       String
  /// Translated lemma (the word itself), e.g. "book" → "книга".
  lemmaText      String?
  /// Part of speech for this gloss (noun, adjective, …). Empty string = legacy single row.
  partOfSpeech   String  @default("")
  word           Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  language       Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([wordId, languageId, partOfSpeech])
  @@index([languageId])
}

enum VocabularyStatus {
  NEW
  REPEATED
  MISTAKES_WORK
  LEARNED
}

model StudentWordCard {
  id               String           @id @default(cuid())
  userId           String
  wordId           String
  /// Optional link to the lesson that introduced the word.
  lessonId         String?
  status           VocabularyStatus @default(NEW)
  masteryLevel     Int              @default(0)
  firstSeenAt      DateTime?
  lastReviewedAt   DateTime?
  nextReviewAt     DateTime?
  knownAt          DateTime?
  knownByTeacherId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  word   Word             @relation(fields: [wordId], references: [id], onDelete: Cascade)
  lesson ScheduledLesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@unique([userId, wordId])
  @@index([userId, status])
  @@index([lessonId])
  @@index([nextReviewAt])
}

model ReviewQueue {
  id           String   @id @default(cuid())
  userId       String
  wordId       String
  dueAt        DateTime
  intervalDays Int      @default(1)
  easeFactor   Float    @default(2.5)
  repetitions  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  word         Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([dueAt])
}

// =====================
// Curriculum lessons (catalog content)
// =====================

model Lesson {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String?
  level       String
  order       Int
  exercises   Exercise[]
  progress    Progress[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Exercise {
  id        String   @id @default(cuid())
  lessonId  String
  prompt    String
  kind      String
  payload   Json
  answer    Json
  order     Int
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Progress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  score       Float?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// =====================
// Scheduled lessons (1:1 sessions with Meet integration)
// =====================

enum LessonStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

enum LessonCancelReason {
  STUDENT_ABSENT
  STUDENT_REQUESTED_CANCEL
  TEACHER_ABSENT
}

enum LessonRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum StudentResponseStatus {
  NOT_SUBMITTED
  SUBMITTED
  NEEDS_REWORK
  ACCEPTED
}

enum ScheduledLessonKind {
  INDIVIDUAL
  GROUP
}

enum GroupLessonBillingMode {
  PER_MEMBER
  FIXED_TOTAL
}

enum GroupFixedSplitMode {
  SINGLE_PAYER
  EQUAL_SPLIT
}

enum LessonParticipantRole {
  STUDENT
  PAYER
}

enum StudentLessonFormat {
  INDIVIDUAL_ONLY
  GROUP_ONLY
  MIXED
}

model ScheduledLesson {
  id          String  @id @default(cuid())
  title       String
  description String?
  notes       String?
  lessonPlan  String?

  /// Wall-clock date for the lesson in `timezone` (yyyy-MM-dd).
  date      String
  /// Wall-clock start time (HH:mm) interpreted in `timezone`.
  startTime String
  endTime   String
  duration  Int
  timezone  String @default("Europe/Kyiv")

  teacherId    String
  /// Primary student (first participant). Kept for backward-compatible queries.
  studentId    String
  kind              ScheduledLessonKind      @default(INDIVIDUAL)
  groupBillingMode  GroupLessonBillingMode?
  groupPriceMinor   Int?
  groupCurrency     String?
  groupSplitMode    GroupFixedSplitMode?
  groupPayerUserId  String?
  studentGroupId    String?
  status       LessonStatus        @default(PLANNED)
  cancelReason LessonCancelReason?
  credited     Boolean             @default(false)

  recurrence LessonRecurrence @default(NONE)
  weeklyDays Int[]
  seriesId   String?

  /// Sort order within a given day for the student/teacher.
  order Int @default(0)

  // Video meeting integration (generalized — supports Google Meet, Zoom, Jitsi)
  /// Provider key when this lesson has a video meeting: 'google' | 'zoom' | 'jitsi'.
  videoProvider          String?
  /// URL students/teachers click to join the meeting (Meet/Zoom/Jitsi).
  videoMeetingUrl        String?
  /// Provider-specific identifier (Google event id, Zoom meeting id, Jitsi room).
  videoMeetingExternalId String?
  /// Raw provider id used to correlate webhooks (e.g. Zoom meeting UUID).
  videoMeetingRawId      String?
  videoMeetingStartedAt  DateTime?
  videoMeetingEndedAt    DateTime?

  // Google Meet integration (legacy fields — kept for backward compat; new code reads videoMeetingUrl with fallback)
  googleCalendarEventId String?
  googleMeetUrl         String?
  googleConferenceId    String?
  meetCreatedAt         DateTime?

  // Homework / student response
  homeworkText            String?
  homeworkFiles           String[]
  studentResponseText     String?
  studentResponseFiles    String[]
  studentResponseStatus   StudentResponseStatus @default(NOT_SUBMITTED)
  homeworkChecked         Boolean               @default(false)
  teacherHomeworkFeedback String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher          User                   @relation("LessonTeacher", fields: [teacherId], references: [id], onDelete: Restrict)
  student          User                   @relation("LessonStudent", fields: [studentId], references: [id], onDelete: Restrict)
  groupPayer       User?                  @relation("GroupLessonPayer", fields: [groupPayerUserId], references: [id], onDelete: SetNull)
  studentGroup     StudentGroup?          @relation(fields: [studentGroupId], references: [id], onDelete: SetNull)
  participants     ScheduledLessonParticipant[]
  materials        LessonMaterial[]
  fileAttachments  LessonFileAttachment[]
  linkedWords      StudentWordCard[]
  quizzes          Quiz[]
  balanceLedger    LessonBalanceLedger[]

  @@index([teacherId, date])
  @@index([studentId, date])
  @@index([seriesId])
  @@index([kind])
  @@index([studentGroupId])
}

model StudentGroup {
  id               String                 @id @default(cuid())
  name             String
  teacherId        String?
  groupBillingMode GroupLessonBillingMode @default(PER_MEMBER)
  groupPriceMinor  Int?
  groupCurrency    String?
  groupSplitMode   GroupFixedSplitMode?
  groupPayerUserId String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  teacher    User?                  @relation("StudentGroupTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  groupPayer User?                  @relation("StudentGroupPayer", fields: [groupPayerUserId], references: [id], onDelete: SetNull)
  members    StudentGroupMember[]
  lessons    ScheduledLesson[]

  @@index([teacherId])
}

model StudentGroupMember {
  id             String @id @default(cuid())
  studentGroupId String
  userId         String
  sortOrder      Int    @default(0)

  studentGroup StudentGroup @relation(fields: [studentGroupId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([studentGroupId, userId])
  @@index([userId])
}

model ScheduledLessonParticipant {
  id                String                @id @default(cuid())
  scheduledLessonId String
  userId            String
  role              LessonParticipantRole @default(STUDENT)
  sortOrder         Int                   @default(0)
  studentResponseText     String?
  studentResponseFiles    String[]
  studentResponseStatus   StudentResponseStatus @default(NOT_SUBMITTED)
  homeworkChecked         Boolean               @default(false)
  teacherHomeworkFeedback String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  lesson ScheduledLesson @relation(fields: [scheduledLessonId], references: [id], onDelete: Cascade)
  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scheduledLessonId, userId])
  @@index([userId])
}

enum MaterialKind {
  TEXT
  PHOTO
  TEST
  FILE
  PRESENTATION
  BOOK
  BOARD
}

model LessonMaterial {
  id                String           @id @default(cuid())
  lessonId          String
  kind              MaterialKind
  text              String?
  files             String[]
  libraryMaterialId String?
  /// Explicit audio/video picks when libraryMediaSelectionApplied is true.
  sharedLibraryAssetIds String[] @default([])
  /// False = share all student audio/video (legacy). True = use sharedLibraryAssetIds.
  libraryMediaSelectionApplied Boolean @default(false)
  order             Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  lesson            ScheduledLesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  libraryMaterial   LibraryMaterial? @relation(fields: [libraryMaterialId], references: [id], onDelete: SetNull)

  @@index([lessonId])
  @@index([libraryMaterialId])
}

model LessonFileAttachment {
  id         String   @id @default(cuid())
  lessonId   String
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  createdAt  DateTime @default(now())
  lesson     ScheduledLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

enum LibraryMaterialKind {
  BOARD
  PRESENTATION
  BOOK
  OTHER
}

enum LibraryMaterialAssetRole {
  STUDENT_BOOK
  TEACHER_BOOK
  WORKBOOK
  AUDIO
  VIDEO
  SLIDES
  LINK
  OTHER
}

enum LibraryMaterialDeliveryKind {
  URL
  FILE
}

model LibraryMaterial {
  id          String              @id @default(cuid())
  title       String
  description String?
  kind        LibraryMaterialKind
  tags        String[]
  level       String?
  publisher   String?
  /// Optional hero/cover image for library cards (uploaded image).
  coverAttachmentId String? @unique
  /// Tenant seam — nullable while single-school.
  schoolId    String?
  createdById String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  createdBy       User                    @relation("LibraryMaterialCreator", fields: [createdById], references: [id], onDelete: Cascade)
  coverAttachment LibraryFileAttachment?  @relation("MaterialCover", fields: [coverAttachmentId], references: [id], onDelete: SetNull)
  assets          LibraryMaterialAsset[]
  fileAttachments LibraryFileAttachment[]
  lessonMaterials LessonMaterial[]

  @@index([kind])
  @@index([schoolId, kind])
  @@index([createdById])
}

model LibraryMaterialAsset {
  id               String                      @id @default(cuid())
  materialId       String
  role             LibraryMaterialAssetRole
  deliveryKind     LibraryMaterialDeliveryKind
  url              String?
  fileAttachmentId String?
  label            String?
  sortOrder        Int                         @default(0)

  material       LibraryMaterial        @relation(fields: [materialId], references: [id], onDelete: Cascade)
  fileAttachment LibraryFileAttachment? @relation(fields: [fileAttachmentId], references: [id], onDelete: SetNull)

  @@index([materialId])
}

model LibraryFileAttachment {
  id         String   @id @default(cuid())
  materialId String
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  /// JPEG/WebP thumbnail of first PDF page (book assets).
  previewStorageKey String?
  createdAt  DateTime @default(now())

  material       LibraryMaterial        @relation(fields: [materialId], references: [id], onDelete: Cascade)
  coverForMaterial LibraryMaterial?     @relation("MaterialCover")
  assets         LibraryMaterialAsset[]
  userAnnotations LibraryFileUserAnnotation[]
  captionTracks   LibraryFileCaptionTrack[]

  @@index([materialId])
}

enum LibraryCaptionTrackKind {
  SOURCE
  TRANSLATION
}

enum LibraryCaptionTrackStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model LibraryFileCaptionTrack {
  id               String                    @id @default(cuid())
  fileAttachmentId String
  language         String
  kind             LibraryCaptionTrackKind
  sourceTrackId    String?
  status           LibraryCaptionTrackStatus @default(PENDING)
  vttStorageKey    String?
  errorMessage     String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  fileAttachment LibraryFileAttachment @relation(fields: [fileAttachmentId], references: [id], onDelete: Cascade)

  @@unique([fileAttachmentId, language, kind])
  @@index([fileAttachmentId])
}

/// Per-user vector annotations on a library PDF file (keyed by file attachment, not lesson).
model LibraryFileUserAnnotation {
  id               String   @id @default(cuid())
  userId           String
  fileAttachmentId String
  /// "" = own book; student id when staff draws on that student's book.
  contextUserId    String   @default("")
  /// Compact vector doc: { version: 1, pages: { "0": Annotation[] } }
  document         Json
  /// Fingerprint to detect stale layer after PDF re-upload (sizeBytes + storageKey).
  fileRevision     String?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileAttachment LibraryFileAttachment @relation(fields: [fileAttachmentId], references: [id], onDelete: Cascade)

  @@unique([userId, fileAttachmentId, contextUserId])
  @@index([fileAttachmentId])
  @@index([contextUserId])
}

// =====================
// Quizzes
// =====================

enum QuizDifficulty {
  EASY
  MEDIUM
  HARD
}

enum QuizSource {
  MANUAL
  VOCABULARY
  LESSON
  MIXED
}

enum QuizQuestionType {
  MULTIPLE_CHOICE
  FILL_IN
}

enum QuizAssignmentStatus {
  PENDING
  SUBMITTED
  GRADED
}

model Quiz {
  id         String         @id @default(cuid())
  title      String
  category   String
  difficulty QuizDifficulty @default(MEDIUM)
  source     QuizSource     @default(MANUAL)
  ownerId    String
  lessonId   String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  owner       User             @relation("QuizOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  lesson      ScheduledLesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  questions   QuizQuestion[]
  assignments QuizAssignment[]
  attempts    QuizAttempt[]

  @@index([ownerId])
  @@index([lessonId])
}

model QuizQuestion {
  id            String           @id @default(cuid())
  quizId        String
  order         Int              @default(0)
  type          QuizQuestionType
  prompt        String
  /// Distractors + correct option for multiple-choice. Empty for fill-in.
  options       String[]
  /// Correct option index (for multiple-choice) serialised as string,
  /// or the expected text for fill-in.
  correctAnswer String
  explanation   String?
  /// Optional link to source word used by the generator.
  wordId        String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  word    Word?        @relation(fields: [wordId], references: [id], onDelete: SetNull)
  answers QuizAnswer[]

  @@index([quizId, order])
}

model QuizAssignment {
  id           String               @id @default(cuid())
  quizId       String
  studentId    String
  assignedById String
  dueDate      DateTime?
  personalNote String?
  status       QuizAssignmentStatus @default(PENDING)
  score        Float?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  quiz       Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student    User          @relation("AssignmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  assignedBy User          @relation("AssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: Cascade)
  attempts   QuizAttempt[]

  @@unique([quizId, studentId])
  @@index([studentId])
  @@index([assignedById])
}

model QuizAttempt {
  id           String    @id @default(cuid())
  quizId       String
  studentId    String
  assignmentId String?
  score        Float?
  correctCount Int       @default(0)
  totalCount   Int       @default(0)
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  quiz       Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student    User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignment QuizAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  answers    QuizAnswer[]

  @@index([quizId])
  @@index([studentId])
}

model QuizAnswer {
  id          String   @id @default(cuid())
  attemptId   String
  questionId  String
  givenAnswer String
  isCorrect   Boolean
  answeredAt  DateTime @default(now())

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

// =====================
// Speaking practice
// =====================

enum SpeakingTopicAssignmentStatus {
  PENDING
  SUBMITTED
  REVIEWED
}

enum SpeakingSubmissionStatus {
  SUBMITTED
  REVIEWED
}

model SpeakingTopic {
  id        String   @id @default(cuid())
  title     String
  prompt    String
  ownerId   String
  wordIds   String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner       User                      @relation("SpeakingTopicOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  assignments SpeakingTopicAssignment[]
  submissions SpeakingSubmission[]

  @@index([ownerId])
}

model SpeakingTopicAssignment {
  id           String                        @id @default(cuid())
  topicId      String
  studentId    String
  assignedById String
  personalNote String?
  dueDate      DateTime?
  status       SpeakingTopicAssignmentStatus @default(PENDING)
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt

  topic       SpeakingTopic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
  student     User                 @relation("SpeakingAssignmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  assignedBy  User                 @relation("SpeakingAssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: Cascade)
  submissions SpeakingSubmission[]

  @@unique([topicId, studentId])
  @@index([studentId])
  @@index([assignedById])
}

model SpeakingSubmission {
  id              String                   @id @default(cuid())
  topicId         String
  assignmentId    String?
  studentId       String
  audioStorageKey String?
  durationSec     Int?
  mimeType        String?
  status          SpeakingSubmissionStatus @default(SUBMITTED)
  teacherFeedback String?
  reviewedById    String?
  reviewedAt      DateTime?
  submittedAt     DateTime                 @default(now())

  topic      SpeakingTopic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  assignment SpeakingTopicAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  student    User                     @relation("SpeakingSubmissionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  reviewer   User?                    @relation("SpeakingSubmissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([topicId])
  @@index([studentId])
  @@index([assignmentId])
}

// =====================
// Realtime chat
// =====================

enum ChatConversationType {
  DIRECT
  GROUP
}

model ChatConversation {
  id          String               @id @default(cuid())
  type        ChatConversationType
  title       String?
  /// For DIRECT: sorted pair `${minUserId}:${maxUserId}` for uniqueness.
  directKey   String?              @unique
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  createdBy    User              @relation("ChatCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  participants ChatParticipant[]
  messages     ChatMessage[]

  @@index([createdById])
  @@index([updatedAt])
}

model ChatParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String   @default("")
  createdAt      DateTime @default(now())

  conversation ChatConversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                    @relation(fields: [senderId], references: [id], onDelete: Cascade)
  attachment   ChatMessageAttachment?

  @@index([conversationId, createdAt])
}

/// Chat file uploads are deleted after 24 hours (`expiresAt`).
model ChatMessageAttachment {
  id         String   @id @default(cuid())
  messageId  String   @unique
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

// =====================
// Platform settings (super-admin)
// =====================

enum WordDictionaryProvider {
  DICTIONARY_API_DEV
  WIKTIONARY
  REVERSO
}

/// Singleton row (`id` = "default") for platform-wide configuration.
model PlatformSettings {
  id                     String                 @id @default("default")
  wordDictionaryProvider WordDictionaryProvider @default(DICTIONARY_API_DEV)
  enabledPaymentMethods  PaymentMethodKind[]    @default([])
  paymentConfig          Json                   @default("{}")
  paymentSecrets         String?
  /// Platform-wide integrations (translation, SMTP, OAuth, Telegram) — non-secret fields.
  integrationConfig      Json                   @default("{}")
  /// AES-GCM encrypted JSON (smtp pass, OAuth secrets, bot token, …).
  integrationSecrets     String?
  /// Default staff payout / compensation settings (school-wide).
  staffPayoutDefaults    Json                   @default("{}")
  updatedAt              DateTime               @updatedAt
}

// =====================
// Lesson billing (prepaid balance)
// =====================

enum PaymentMethodKind {
  MANUAL_INVOICE
  STRIPE
  LIQPAY
  WAYFORPAY
  LEMON_SQUEEZY
  PADDLE
  MONOPAY
  PAYPAL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum LessonBalanceLedgerKind {
  PURCHASE
  MANUAL_CREDIT
  CONSUMPTION
  REVERSAL
  GROUP_CHARGE
  GROUP_CHARGE_REVERSAL
  GROUP_PURCHASE
  GROUP_MANUAL_CREDIT
  GROUP_CONSUMPTION
  GROUP_REVERSAL
}

enum StaffCompensationMode {
  PER_LESSON
  SALARY
  MIXED
}

enum StaffPayFrequency {
  WEEKLY
  MONTHLY
}

/// Per-staff compensation overrides (teachers, admins). Null fields fall back to platform defaults.
model StaffCompensationProfile {
  id                String                 @id @default(cuid())
  userId            String                 @unique
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode              StaffCompensationMode?
  perLessonRateMinor Int?
  salaryMinor       Int?
  currency          String?
  payFrequency      StaffPayFrequency?
  /// 0 = Sunday … 6 = Saturday when payFrequency = WEEKLY
  payDayOfWeek      Int?
  /// 1–28 when payFrequency = MONTHLY
  payDayOfMonth     Int?
  graceDays         Int?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

/// Manual staff payout records entered by admin/super-admin.
model StaffPayout {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("StaffPayoutPayee", fields: [userId], references: [id], onDelete: Cascade)
  amountMinor     Int
  currency        String
  paidAt          DateTime
  periodFrom      DateTime?
  periodTo        DateTime?
  note            String?
  createdByUserId String
  createdBy       User     @relation("StaffPayoutCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime @default(now())

  @@index([userId, paidAt])
  @@index([createdAt])
}

enum StudentBillingMode {
  PER_LESSON
  PACKAGES
  BOTH
}

/// One row per student; balance may be negative (debt).
model StudentLessonBalance {
  userId               String              @id
  balance              Int                 @default(0)
  /// Prepaid credits for group per-member lessons (separate from individual balance).
  groupBalance         Int                 @default(0)
  /// Override platform price-per-lesson (minor units); null = use platform default.
  pricePerLessonMinor  Int?
  /// Override platform group per-member price (minor units); null = use groupLessons.defaultPriceMinor.
  groupPricePerLessonMinor Int?
  /// How this student is billed (per lesson, packages, or both).
  billingMode          StudentBillingMode  @default(BOTH)
  /// Per-student package rules: fixed lesson counts, enabled flags (JSON array).
  packageOverrides     Json?
  /// Per-student payment-method restriction: allowlist of enabled platform payment methods.
  paymentMethodSelection Json?
  /// Per-student manual invoice restrictions: allowlist + optional default method id.
  manualInvoiceSelection Json?
  updatedAt            DateTime            @updatedAt
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LessonBalanceLedger {
  id                String                  @id @default(cuid())
  userId            String
  delta             Int
  balanceAfter      Int
  kind              LessonBalanceLedgerKind
  scheduledLessonId String?
  paymentId         String?
  createdById       String?
  note              String?
  /// Monetary amount for GROUP_CHARGE rows (minor units).
  amountMinor       Int?
  currency          String?
  createdAt         DateTime                @default(now())

  user            User             @relation("LessonBalanceLedgerUser", fields: [userId], references: [id], onDelete: Cascade)
  scheduledLesson ScheduledLesson? @relation(fields: [scheduledLessonId], references: [id], onDelete: SetNull)
  payment         Payment?         @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdBy       User?            @relation("LessonBalanceLedgerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([scheduledLessonId, userId, kind])
  @@index([userId, createdAt])
}

model Payment {
  id             String            @id @default(cuid())
  userId         String
  method         PaymentMethodKind
  status         PaymentStatus     @default(PENDING)
  lessonsGranted Int               @default(0)
  amountMinor    Int
  currency       String            @default("UAH")
  externalId     String?           @unique
  metadata       Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgerEntries LessonBalanceLedger[]

  @@index([userId, createdAt])
}
