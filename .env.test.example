# Copy to .env.test or export before `npm run test:integration`
# Requires PostgreSQL with migrations applied (see README in tests/integration).

DATABASE_URL=postgresql://soenglish:soenglish@localhost:5432/soenglish_test?schema=public
JWT_SECRET=arvilio-test-jwt-secret-min-32-chars-long
RUN_INTEGRATION_TESTS=1

# Playwright E2E — run `npm run seed:test-users` first
PLAYWRIGHT_TEST_EMAIL=jest-student@arvilio.test
PLAYWRIGHT_TEST_PASSWORD=TestPass123!
PLAYWRIGHT_TEACHER_EMAIL=jest-teacher@arvilio.test
PLAYWRIGHT_TEACHER_PASSWORD=TestPass123!
